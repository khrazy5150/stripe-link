{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.stripe-link.local/CalendarConnection.schema.json",
  "title": "CalendarConnection",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "document_type", "tenant_id", "connection_id", "provider", "status"],
  "properties": {
    "schema_version": { "type": "string" },
    "document_type": { "const": "calendar_connection" },
    "tenant_id": { "type": "string" },
    "connection_id": { "type": "string" },
    "provider": { "enum": ["google"] },
    "calendar_id": { "type": "string" },
    "account_email": { "type": "string" },
    "scopes": { "type": "array", "items": { "type": "string" } },
    "refresh_token_ref": { "type": "string" },
    "status": { "enum": ["connected", "revoked", "error"] },
    "connected_at": { "type": "integer" },
    "updated_at": { "type": "integer" }
  }
}
