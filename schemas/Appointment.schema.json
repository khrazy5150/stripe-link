{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.stripe-link.local/Appointment.schema.json",
  "title": "Appointment",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "document_type", "tenant_id", "appointment_id", "service_id", "status", "customer"],
  "properties": {
    "schema_version": { "type": "string" },
    "document_type": { "const": "appointment" },
    "tenant_id": { "type": "string" },
    "appointment_id": { "type": "string" },
    "service_id": { "type": "string" },
    "service_name": { "type": "string" },
    "starts_at": { "type": ["string", "null"] },
    "ends_at": { "type": ["string", "null"] },
    "timezone": { "type": ["string", "null"] },
    "awaiting_schedule": { "type": "boolean" },
    "booking_flow": { "enum": ["book_then_pay", "pay_then_book"] },
    "order_id": { "type": "string" },
    "offer_id": { "type": "string" },
    "invoice_id": { "type": "string" },
    "page_id": { "type": "string" },
    "source": { "enum": ["booking_page", "offer", "invoice"] },
    "status": { "enum": ["reserved", "booked", "paid", "checked_in", "completed", "canceled", "no_show"] },
    "payment_status": { "enum": ["unpaid", "pending", "paid", "refunded"] },
    "assigned_fulfiller_id": { "type": "string" },
    "customer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["email"],
      "properties": {
        "customer_id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "sms_opted_out": { "type": "boolean" }
      }
    },
    "price": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "currency": { "type": "string" },
        "unit_amount": { "type": "integer", "minimum": 0 }
      }
    },
    "service_location": { "type": "object" },
    "rule_snapshot": { "type": "object" },
    "manage_token_ref": { "type": "string" },
    "customer_manage_token": { "type": "string" },
    "payment_intent_id": { "type": "string" },
    "delegation_calendar": { "enum": ["written", "unavailable"] },
    "external_calendar_events": {
      "type": "array",
      "items": { "type": "object" }
    },
    "reminders": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["lead_minutes", "channel", "status"],
        "properties": {
          "lead_minutes": { "type": "integer", "minimum": 1 },
          "channel": { "enum": ["sms"] },
          "send_at": { "type": ["integer", "null"] },
          "status": { "enum": ["scheduled", "sent", "canceled", "failed"] },
          "sent_at": { "type": ["integer", "null"] },
          "message_id": { "type": "string" },
          "attempts": { "type": "integer", "minimum": 0 },
          "error": { "type": "string" }
        }
      }
    },
    "hold_expires_at": { "type": ["integer", "null"] },
    "checked_in_at": { "type": ["string", "null"] },
    "completed_at": { "type": ["string", "null"] },
    "canceled_at": { "type": ["string", "null"] },
    "created_at": { "type": "integer" },
    "updated_at": { "type": "integer" }
  }
}
