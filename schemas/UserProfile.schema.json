{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.juniorbay.com/stripe-link/UserProfile.schema.json",
  "title": "UserProfile",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "document_type", "tenant_id", "user_id", "email", "display_name"],
  "properties": {
    "schema_version": { "type": "string", "const": "2026-05-29" },
    "document_type": { "type": "string", "const": "user_profile" },
    "tenant_id": { "type": "string", "minLength": 1 },
    "user_id": { "type": "string", "minLength": 1 },
    "email": { "type": "string", "minLength": 3 },
    "display_name": { "type": "string", "minLength": 1 },
    "first_name": { "type": "string" },
    "last_name": { "type": "string" },
    "role": { "type": "string", "enum": ["owner", "admin", "user", "support"], "default": "user" },
    "status": { "type": "string", "enum": ["active", "pending_confirmation", "disabled"], "default": "active" },
    "avatar": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "selected_image_id": { "type": "string" },
        "url": { "type": "string" },
        "initials": { "type": "string", "maxLength": 4 },
        "background_color": { "type": "string" }
      }
    },
    "profile_images": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_images": { "type": "integer", "minimum": 1, "maximum": 10, "default": 10 },
        "max_size_bytes": { "type": "integer", "minimum": 1, "default": 10485760 },
        "allowed_mime_types": {
          "type": "array",
          "items": { "type": "string", "enum": ["image/png", "image/jpeg", "image/webp"] },
          "default": ["image/png", "image/jpeg", "image/webp"]
        },
        "images": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["image_id", "url", "uploaded_at"],
            "properties": {
              "image_id": { "type": "string" },
              "url": { "type": "string" },
              "s3_key": { "type": "string" },
              "mime_type": { "type": "string", "enum": ["image/png", "image/jpeg", "image/webp"] },
              "size_bytes": { "type": "integer", "minimum": 0 },
              "width": { "type": "integer", "minimum": 1 },
              "height": { "type": "integer", "minimum": 1 },
              "is_selected": { "type": "boolean", "default": false },
              "uploaded_at": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string", "enum": ["cognito"], "default": "cognito" },
        "cognito_username": { "type": "string" },
        "email_verified": { "type": "boolean", "default": false },
        "mfa_enabled": { "type": "boolean", "default": false },
        "last_login_at": { "type": "integer", "minimum": 0 },
        "password_updated_at": { "type": "integer", "minimum": 0 }
      }
    },
    "subscription": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "account_status": { "type": "string", "enum": ["inactive", "trial", "active", "past_due", "canceled"], "default": "inactive" },
        "tier_id": { "type": "string" },
        "billing_status": { "type": "string" },
        "activation_available": { "type": "boolean", "default": true },
        "activated_at": { "type": "integer", "minimum": 0 },
        "stripe_customer_id": { "type": "string" },
        "stripe_subscription_id": { "type": "string" }
      }
    },
    "created_at": { "type": "integer", "minimum": 0 },
    "updated_at": { "type": "integer", "minimum": 0 }
  }
}
