{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.juniorbay.com/stripe-link/Offer.schema.json",
  "title": "Offer",
  "description": "An offer is a presentation and checkout wrapper around one or more product prices. Products must share product_intent and stripe_mode. Product price context drives landing page placement; subscriptions are represented by price pricing_model and checkout.mode.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "document_type",
    "tenant_id",
    "offer_id",
    "slug",
    "name",
    "status",
    "product_intent",
    "stripe_mode",
    "items",
    "discount",
    "sync",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2026-05-29"
    },
    "document_type": {
      "type": "string",
      "const": "offer"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "offer_id": {
      "type": "string",
      "minLength": 1,
      "description": "System-generated unique identifier for this offer."
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "URL-friendly identifier generated from the offer name. Must be unique per tenant."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable offer label shown in the dashboard and optionally in customer-facing presentation."
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "archived"],
      "description": "Lifecycle status. Replaces the older boolean active flag."
    },
    "product_intent": {
      "type": "string",
      "enum": ["transaction", "lead_gen"],
      "description": "All offer items must share this product intent. This is resolved from selected products by the API."
    },
    "offer_type": {
      "type": "string",
      "enum": ["single", "bundle", "listicle"],
      "default": "single",
      "description": "Drives landing-page rendering. single/bundle -> pick-one price selector; listicle -> a carousel of the offer's items, each independently add-to-cart. See plans/LISTICLE_AND_CART.md."
    },
    "stripe_mode": {
      "type": "string",
      "enum": ["test", "live"],
      "description": "All offer items must belong to this Stripe mode."
    },
    "context": {
      "type": "string",
      "enum": ["standard", "sale", "flash_sale", "upsell", "downsell", "order_bump"],
      "default": "standard",
      "description": "Deprecated transition field. Product price context now drives landing page placement; recurring billing belongs to product price pricing_model and checkout.mode."
    },
    "trigger_offer_id": {
      "type": ["string", "null"],
      "description": "Deprecated transition field. Triggering and funnel placement are handled by landing page/flow configuration."
    },
    "service_booking_mode": {
      "enum": ["single_visit", "separate_visits"],
      "default": "single_visit",
      "description": "How the offer's scheduled services are delivered: single_visit collapses them into one appointment; separate_visits gives each its own. no_booking services are never booked. Shorthand expanded by booking_groups_for(offer)."
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "description": "Products and/or services included in this offer. Each item references exactly one of product_id or service_id and an existing price_id, rather than duplicating product/service or price documents.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "description": "Exactly one of product_id or service_id is required (enforced by validate_offer_document). Service items use the fixed price_id path only.",
        "properties": {
          "product_id": {
            "type": "string",
            "minLength": 1
          },
          "service_id": {
            "type": "string",
            "minLength": 1,
            "description": "References a Service document; the item is a first-class bookable service."
          },
          "booking_flow": {
            "enum": ["book_then_pay", "pay_then_book"],
            "description": "Per-item override of the service's default booking flow. Service items only."
          },
          "price_id": {
            "type": "string",
            "minLength": 1,
            "description": "References a price_id on the product document, or on Service.prices[] for service items."
          },
          "quantity": {
            "type": "integer",
            "minimum": 1,
            "default": 1,
            "description": "Checkout line item quantity multiplier for the fixed price path."
          },
          "selectable_prices": {
            "type": "array",
            "minItems": 1,
            "description": "Price options the buyer can choose from for this product within this offer.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["price_id"],
              "properties": {
                "price_id": {
                  "type": "string",
                  "minLength": 1
                },
                "quantity": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Units represented by this selectable price option. Usually mirrors the referenced product price quantity."
                },
                "label": {
                  "type": "string",
                  "description": "Customer-facing label such as '1 Bottle' or '2 Bottles'."
                },
                "badge": {
                  "type": "string",
                  "description": "Short badge text such as 'Most Popular' or 'Best Value'."
                },
                "image_url": {
                  "type": "string",
                  "format": "uri-reference",
                  "description": "Offer-specific image override for this selectable price option."
                },
                "display_discount_pct": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100,
                  "description": "Display-only discount percentage. Does not affect Stripe pricing."
                },
                "subscription_incentive": {
                  "$ref": "#/$defs/subscriptionIncentive",
                  "description": "Incentive for a referenced recurring price."
                }
              }
            }
          },
          "default_price_id": {
            "type": "string",
            "minLength": 1,
            "description": "The price_id preselected when the offer renders. API validation must ensure this exists in selectable_prices."
          },
          "display_discount_pct": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "Item-level display-only discount override. Does not affect Stripe pricing."
          },
          "presentation_context": {
            "type": "string",
            "enum": ["primary", "post_purchase", "order_bump", "cross_sell"],
            "description": "Deprecated transition field. Prefer price.context and landing page placement rules."
          },
          "subscription_incentive": {
            "$ref": "#/$defs/subscriptionIncentive",
            "description": "Incentive for a fixed recurring price path."
          }
        }
      }
    },
    "discount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "description": "Offer-level discount configuration. Use { mode: 'none' } when no discount applies. Not applicable to lead_gen offers beyond explicit none.",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["none", "auto", "coupon_code", "promotion_code"]
        },
        "coupon_id": {
          "type": "string",
          "description": "Reference to a Stripe-first Coupon document. Required when mode is coupon_code."
        },
        "promotion_code": {
          "type": "string",
          "description": "Public Stripe promotion code entered by the tenant. Required when mode is promotion_code."
        },
        "type": {
          "type": "string",
          "enum": ["percent", "fixed"],
          "description": "Required when mode is auto."
        },
        "value": {
          "type": "number",
          "minimum": 0,
          "description": "Percentage when type is percent. Smallest currency unit when type is fixed."
        },
        "currency": {
          "type": "string",
          "pattern": "^[a-z]{3}$",
          "description": "Required when type is fixed."
        },
        "duration": {
          "type": "string",
          "enum": ["once", "repeating", "forever"],
          "description": "Stripe coupon duration for subscription checkout. One-time payment offers should use once."
        },
        "duration_months": {
          "type": "integer",
          "minimum": 1,
          "description": "Required when duration is repeating."
        },
        "first_time_only": {
          "type": "boolean",
          "default": false
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "mode": { "const": "none" } },
            "required": ["mode"]
          },
          "then": {
            "not": {
              "anyOf": [
                { "required": ["coupon_id"] },
                { "required": ["promotion_code"] },
                { "required": ["type"] },
                { "required": ["value"] }
              ]
            }
          }
        },
        {
          "if": {
            "properties": { "mode": { "const": "coupon_code" } },
            "required": ["mode"]
          },
          "then": {
            "required": ["coupon_id"]
          }
        },
        {
          "if": {
            "properties": { "mode": { "const": "promotion_code" } },
            "required": ["mode"]
          },
          "then": {
            "required": ["promotion_code"]
          }
        },
        {
          "if": {
            "properties": { "mode": { "const": "auto" } },
            "required": ["mode"]
          },
          "then": {
            "required": ["type", "value"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "fixed" } },
            "required": ["type"]
          },
          "then": {
            "required": ["currency"]
          }
        },
        {
          "if": {
            "properties": { "duration": { "const": "repeating" } },
            "required": ["duration"]
          },
          "then": {
            "required": ["duration_months"]
          }
        }
      ]
    },
    "eligibility": {
      "type": "object",
      "additionalProperties": false,
      "description": "Rules that control when and to whom this offer is available.",
      "properties": {
        "requires_prior_purchase": {
          "type": "boolean",
          "default": false
        },
        "allowed_price_contexts": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["standard", "sale", "flash_sale", "upsell", "downsell", "order_bump"]
          }
        },
        "starts_at": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "ends_at": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      }
    },
    "presentation": {
      "type": "object",
      "additionalProperties": true,
      "description": "Offer-level copy, badges, urgency signals, and display metadata snapshotted from the primary item at save time. These are self-contained suggestions the tenant/AI can override; only price stays resolved-live.",
      "properties": {
        "headline": { "type": "string" },
        "subheadline": { "type": "string" },
        "badge": { "type": "string" },
        "cta_label": { "type": "string" },
        "hero_image_url": { "type": "string" },
        "cta": {
          "type": "object",
          "additionalProperties": false,
          "description": "The offer's CTA contract. type selects which CTA component the landing page renders; the offer is the page's single source of truth for this.",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["buy", "call", "email", "external", "download", "booking", "appointment"],
              "description": "buy = price card + Stripe checkout; call = tel: button + phone banner; email = inline capture form; external = link out; download = download a file; booking/appointment = inline booking calendar."
            },
            "label": {
              "type": "string",
              "description": "Button label."
            },
            "target": {
              "type": "string",
              "description": "Phone number (call), URL (external), or service_id (booking). Empty for buy/email."
            }
          }
        }
      }
    },
    "refund_policy": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional offer-level refund policy override. When absent, the renderer falls back to product policy or tenant preferences.",
      "required": ["source", "refund_window", "condition", "return_method", "short_label", "full_policy"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["product", "offer_override", "user_preference_default"]
        },
        "product_id": {
          "type": "string"
        },
        "refund_window": {
          "type": "string",
          "enum": ["non_refundable", "72_hours", "7_days", "14_days", "30_days", "60_days", "custom"]
        },
        "condition": {
          "type": "string",
          "enum": ["any", "unused", "unopened", "defective_only", "not_downloaded", "custom"]
        },
        "return_method": {
          "type": "string",
          "enum": ["no_return_customer_keeps", "return_required", "digital_revoke_access", "custom"]
        },
        "short_label": {
          "type": "string"
        },
        "full_policy": {
          "type": "string"
        }
      }
    },
    "checkout": {
      "type": "object",
      "additionalProperties": false,
      "description": "Stripe checkout session configuration. Required for transaction offers and omitted for lead_gen offers.",
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["payment", "subscription"],
          "description": "payment for one-time purchases. subscription for recurring product prices."
        },
        "success_url": {
          "type": "string"
        },
        "cancel_url": {
          "type": "string"
        },
        "phone_number_collection": {
          "type": "string",
          "enum": ["inherit", "enabled", "disabled"],
          "default": "inherit"
        },
        "allow_promotion_codes": {
          "type": "boolean",
          "default": false
        },
        "shipping": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "required": {
              "type": "boolean"
            },
            "allowed_countries": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^[A-Z]{2}$"
              }
            }
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "integer", "boolean", "null"]
          }
        }
      }
    },
    "sync": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "last_synced_at", "error"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "synced", "error"]
        },
        "last_synced_at": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "error": {
          "type": ["string", "null"]
        }
      }
    },
    "created_at": {
      "type": "integer",
      "minimum": 0
    },
    "updated_at": {
      "type": "integer",
      "minimum": 0
    }
  },
  "$defs": {
    "subscriptionIncentive": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["none", "free_trial", "discount_percent", "discount_fixed", "paid_trial"]
        },
        "trial_days": {
          "type": "integer",
          "minimum": 1
        },
        "discount_value": {
          "type": "number",
          "minimum": 0
        },
        "discount_currency": {
          "type": "string",
          "pattern": "^[a-z]{3}$"
        },
        "discount_duration": {
          "type": "string",
          "enum": ["once", "repeating", "forever"]
        },
        "discount_duration_months": {
          "type": "integer",
          "minimum": 1
        },
        "paid_trial_amount": {
          "type": "integer",
          "minimum": 1
        },
        "paid_trial_currency": {
          "type": "string",
          "pattern": "^[a-z]{3}$"
        },
        "paid_trial_cycles": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "requires_flexible_billing": {
          "type": "boolean",
          "const": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "free_trial" } },
            "required": ["type"]
          },
          "then": {
            "required": ["trial_days"]
          }
        },
        {
          "if": {
            "properties": { "type": { "enum": ["discount_percent", "discount_fixed"] } },
            "required": ["type"]
          },
          "then": {
            "required": ["discount_value", "discount_duration"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "discount_fixed" } },
            "required": ["type"]
          },
          "then": {
            "required": ["discount_currency"]
          }
        },
        {
          "if": {
            "properties": { "discount_duration": { "const": "repeating" } },
            "required": ["discount_duration"]
          },
          "then": {
            "required": ["discount_duration_months"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "paid_trial" } },
            "required": ["type"]
          },
          "then": {
            "required": ["paid_trial_amount", "paid_trial_currency", "paid_trial_cycles", "requires_flexible_billing"]
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "product_intent": { "const": "transaction" } },
        "required": ["product_intent"]
      },
      "then": {
        "required": ["checkout"]
      }
    },
    {
      "if": {
        "properties": { "product_intent": { "const": "lead_gen" } },
        "required": ["product_intent"]
      },
      "then": {
        "not": { "required": ["checkout"] },
        "properties": {
          "discount": {
            "properties": { "mode": { "const": "none" } },
            "required": ["mode"]
          }
        }
      }
    }
  ]
}
