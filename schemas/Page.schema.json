  {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://schemas.juniorbay.com/stripe-link/Page.schema.json",
    "title": "Page",
    "type": "object",
    "additionalProperties": false,
    "required": [
      "schema_version",
      "document_type",
      "tenant_id",
      "page_id",
      "name",
      "route",
      "offer_id",
      "sections"
    ],
    "properties": {
      "schema_version": {
        "type": "string",
        "const": "2026-05-29"
      },
      "document_type": {
        "type": "string",
        "const": "page"
      },
      "tenant_id": {
        "type": "string",
        "minLength": 1
      },
      "page_id": {
        "type": "string",
        "minLength": 1
      },
      "name": {
        "type": "string",
        "minLength": 1
      },
    "status": {
      "type": "string",
      "enum": ["draft", "published", "archived"],
      "default": "draft"
    },
    "published_at": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Timestamp when status moved to published. Kept separate from updated_at for audit history and rollback UI."
    },
      "route": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slug"],
        "properties": {
          "slug": {
            "type": "string",
            "minLength": 1
          },
          "domain": {
            "type": "string"
          },
          "short_code": {
            "type": "string"
          }
        }
      },
      "seo": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "image": {
            "type": "string"
          },
          "favicon_url": {
            "type": "string",
            "description": "Optional favicon URL. When omitted, the renderer uses Junior Bay's default favicon."
          }
        }
      },
      "offer_id": {
        "type": "string",
        "minLength": 1
      },
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "description": "Landing page template and color theme settings. Presets define the Universal Bundle base styles; tokens override individual CSS variables for tenant-saved themes.",
      "properties": {
        "template": {
          "type": "string",
          "enum": ["simple", "universal_bundle"]
        },
        "preset": {
          "type": "string",
          "enum": [
            "techno-green",
            "rose-minimalist",
            "midnight-luxe",
            "trust-blue",
            "coral-sunrise",
            "clean-slate",
            "royal-velvet",
            "fire-sale",
            "natural-calm",
            "cyber-pulse"
          ]
        },
        "color": {
          "type": "object",
          "additionalProperties": false,
          "description": "Legacy simple-template color overrides.",
          "properties": {
            "background": { "$ref": "#/$defs/hexColor" },
            "text": { "$ref": "#/$defs/hexColor" },
            "accent": { "$ref": "#/$defs/hexColor" }
          }
        },
        "tokens": {
          "type": "object",
          "description": "Universal Bundle CSS variable overrides. Keys map to renderer tokens such as background, card, brand, cta_from, savings_bg, and featured_badge_text.",
          "additionalProperties": { "$ref": "#/$defs/hexColor" }
        },
        "fonts": {
          "type": "object",
          "additionalProperties": false,
          "description": "Landing page font settings. Font families are resolved by the renderer into CSS variables so services such as Junior Bay can be integrated without changing template CSS.",
          "properties": {
            "service": {
              "type": "string",
              "enum": ["system", "junior-bay"],
              "default": "system"
            },
            "body": { "$ref": "#/$defs/fontRole" },
            "heading": { "$ref": "#/$defs/fontRole" },
            "accent": { "$ref": "#/$defs/fontRole" }
          }
        }
      }
    },
    "post_checkout": {
      "type": "object",
      "description": "Handles routing after a transaction. Can define inline routing owned by the page, or reference a detached Funnel document.",
      "unevaluatedProperties": false,
      "oneOf": [
        {
          "description": "Phase 1: Inline configuration owned by the page.",
          "required": ["thank_you_page"],
          "additionalProperties": false,
          "properties": {
            "thank_you_page": { "$ref": "#/$defs/thankYouPage" },
            "funnel_steps": { "$ref": "#/$defs/funnelStepsArray" }
          }
        },
        {
          "description": "Phase 2: External funnel resolution.",
          "required": ["funnel_id"],
          "additionalProperties": false,
          "properties": {
            "funnel_id": {
              "type": "string",
              "minLength": 1,
              "description": "References a detached Funnel document that handles all post-checkout routing."
            }
          }
        }
      ]
    },
    "analytics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "google_tag_id": {
          "type": "string"
        },
        "pixel_id": {
          "type": "string"
        }
      }
    },
    "legal": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "terms_url": {
          "type": "string"
        },
        "privacy_url": {
          "type": "string"
        },
        "refund_url": {
          "type": "string"
        }
      }
    },
    "refund_policy": {
      "type": "object",
      "additionalProperties": false,
      "description": "Customer-facing refund policy snapshot resolved from offer settings, which may derive from product settings originally seeded by user preferences.",
      "required": ["source", "short_label", "full_policy"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["offer", "product", "user_preference_default", "manual_page_override"]
        },
        "offer_id": { "type": "string" },
        "product_id": { "type": "string" },
        "refund_window": {
          "type": "string",
          "enum": ["non_refundable", "72_hours", "7_days", "14_days", "30_days", "60_days", "custom"]
        },
        "condition": {
          "type": "string",
          "enum": ["any", "unused", "unopened", "defective_only", "not_downloaded", "custom"]
        },
        "return_method": {
          "type": "string",
          "enum": ["no_return_customer_keeps", "return_required", "digital_revoke_access", "custom"]
        },
        "short_label": { "type": "string" },
        "full_policy": { "type": "string" }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
        "items": {
          "type": "object",
          "additionalProperties": true,
          "required": ["id", "type"],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "type": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      },
      "revision": {
        "type": "integer",
        "minimum": 1,
        "default": 1
      },
      "created_at": {
        "type": "integer",
        "minimum": 0
      },
      "updated_at": {
        "type": "integer",
        "minimum": 0
    }
  },
  "$defs": {
    "hexColor": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    },
    "fontRole": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "family": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9 ._-]{0,79}$"
        },
        "fallback": {
          "type": "string",
          "enum": ["system", "sans-serif", "serif", "monospace"],
          "default": "system"
        }
      }
    },
    "thankYouPage": {
      "type": "object",
      "description": "Terminal post-checkout destination. Use page_id for an internal page or url for an external destination.",
      "oneOf": [
        {
          "required": ["page_id"],
          "additionalProperties": false,
          "properties": {
            "page_id": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "required": ["url"],
          "additionalProperties": false,
          "properties": {
            "url": {
              "type": "string",
              "format": "uri",
              "minLength": 1
            }
          }
        }
      ]
    },
    "funnelStepsArray": {
      "type": "array",
      "description": "Inline post-checkout funnel steps. The engine starts at index 0; on_accept and on_decline point to another step_id or the reserved thank_you terminal.",
      "minItems": 1,
      "items": { "$ref": "#/$defs/funnelStep" }
    },
    "funnelStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step_id", "page_id"],
      "properties": {
        "step_id": {
          "type": "string",
          "minLength": 1
        },
        "page_id": {
          "type": "string",
          "minLength": 1
        },
        "on_accept": {
          "type": "string",
          "minLength": 1,
          "description": "Next step_id, or thank_you to terminate the funnel."
        },
        "on_decline": {
          "type": "string",
          "minLength": 1,
          "description": "Next step_id, or thank_you to terminate the funnel."
        }
      }
    }
  }
}
