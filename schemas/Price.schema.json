{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.juniorbay.com/stripe-link/Price.schema.json",
  "title": "Price",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "price_id",
    "currency",
    "quantity"
  ],
  "properties": {
    "price_id": {
      "type": "string",
      "minLength": 1
    },
    "stripe_price_id": {
      "type": ["string", "null"],
      "description": "Stripe price ID after synchronization. Null for local prices that have not synced yet."
    },
    "previous_price_id": {
      "type": ["string", "null"],
      "description": "Optional lineage pointer when an archived Stripe Price is replaced."
    },
    "currency": {
      "type": "string",
      "pattern": "^[a-z]{3}$"
    },
    "unit_amount": {
      "type": "integer",
      "minimum": 0,
      "description": "Sale amount charged to the customer in the smallest currency unit."
    },
    "tenant_keyed_amount": {
      "type": "integer",
      "minimum": 0,
      "description": "Amount entered by the tenant before fee-handling adjustments. For net_guaranteed prices, unit_amount is grossed up from this value."
    },
    "compare_at_unit_amount": {
      "type": "integer",
      "minimum": 0,
      "description": "Higher reference amount shown as a struck-through regular price."
    },
    "quantity": {
      "type": "integer",
      "minimum": 1,
      "description": "Quantity represented by this Stripe Price, such as units in a bundle or sessions in a package."
    },
    "badge": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "image_url": {
      "type": "string",
      "format": "uri-reference"
    },
    "context": {
      "type": "string",
      "enum": ["standard", "sale", "flash_sale", "upsell", "downsell", "order_bump"]
    },
    "discount_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "pricing_model": {
      "type": "string",
      "enum": ["one_time", "recurring", "customer_chooses"],
      "default": "one_time"
    },
    "min_amount": {
      "type": "integer",
      "minimum": 0,
      "description": "Minimum amount the customer can enter. Used when pricing_model is customer_chooses."
    },
    "suggested_amount": {
      "type": "integer",
      "minimum": 0,
      "description": "Pre-filled suggested amount shown to the customer. Used when pricing_model is customer_chooses."
    },
    "recurring": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["interval"],
          "properties": {
            "interval": {
              "type": "string",
              "enum": ["day", "week", "month", "year"]
            },
            "interval_count": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            },
            "trial_period_days": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      ]
    },
    "fee_handling": {
      "type": "string",
      "enum": ["standard", "net_guaranteed"]
    },
    "fee_breakdown": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tenant_keyed_amount", "stripe_fee", "platform_fee", "net_payout"],
      "properties": {
        "tenant_keyed_amount": {
          "type": "integer",
          "minimum": 0
        },
        "stripe_fee": {
          "type": "integer",
          "minimum": 0
        },
        "platform_fee": {
          "type": "integer",
          "minimum": 0
        },
        "net_payout": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "integer", "boolean", "null"]
      }
    },
    "created_at": {
      "type": "integer",
      "minimum": 0
    },
    "updated_at": {
      "type": "integer",
      "minimum": 0
    }
  },
  "if": {
    "required": ["pricing_model"],
    "properties": {
      "pricing_model": { "const": "customer_chooses" }
    }
  },
  "then": {
    "properties": {
      "unit_amount": { "minimum": 0 }
    }
  },
  "else": {
    "required": ["unit_amount"]
  }
}
