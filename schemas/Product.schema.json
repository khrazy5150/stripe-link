{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.juniorbay.com/stripe-link/Product.schema.json",
  "title": "Product",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "document_type",
    "tenant_id",
    "product_id",
    "stripe_product_id",
    "canonical",
    "status",
    "name",
    "prices",
    "default_price_id",
    "fulfillment",
    "sync",
    "tags"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2026-05-29"
    },
    "document_type": {
      "type": "string",
      "const": "product"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "product_id": {
      "type": "string",
      "minLength": 1
    },
    "stripe_product_id": {
      "type": ["string", "null"],
      "description": "Stripe product ID after synchronization. Null for local products that have not synced yet."
    },
    "stripe_mode": {
      "type": "string",
      "enum": ["test", "live"]
    },
    "canonical": {
      "type": "boolean",
      "description": "True only after this product shape is accepted as canonical by the API."
    },
    "status": {
      "type": "string",
      "enum": ["active", "archived"],
      "description": "Product lifecycle status. Archived products are hidden from the default active product list."
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "images": {
      "type": "array",
      "description": "Canonical product imagery. Offer-specific bundle/composite presentation images can override this from Offer items.",
      "items": {
        "type": "string",
        "format": "uri-reference"
      },
      "default": []
    },
    "product_intent": {
      "type": "string",
      "enum": ["transaction", "lead_gen"]
    },
    "product_type": {
      "type": "string"
    },
    "product_category": {
      "type": "string",
      "minLength": 1
    },
    "refund_policy": {
      "type": "object",
      "additionalProperties": false,
      "description": "Product-level refund policy. New products may copy this from the creating user's UserPreferences.authoring_defaults.refund_policies by product class.",
      "required": ["source", "short_label", "full_policy"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["user_preference_default", "tenant_default", "product_override", "user_preferences.physical_products"]
        },
        "refund_window": {
          "type": "string",
          "enum": ["non_refundable", "72_hours", "7_days", "14_days", "30_days", "60_days", "custom"]
        },
        "condition": {
          "type": "string",
          "enum": ["any", "unused", "unopened", "defective_only", "not_downloaded", "custom"]
        },
        "return_method": {
          "type": "string",
          "enum": ["no_return_customer_keeps", "return_required", "digital_revoke_access", "custom"]
        },
        "short_label": { "type": "string" },
        "full_policy": { "type": "string" }
      }
    },
    "lead_capture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "title", "description"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["capture_email", "capture_phone", "capture_email_phone", "call_number", "external_url", "open_form", "social_redirect"]
        },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "type", "required"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "type": { "type": "string", "minLength": 1 },
              "required": { "type": "boolean" }
            }
          }
        },
        "target": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["phone", "url", "form", "social"]
            },
            "value": { "type": "string" },
            "form_id": { "type": "string" },
            "platform": { "type": "string" },
            "open": {
              "type": "string",
              "enum": ["new_tab", "same_tab", "modal"]
            }
          }
        }
      }
    },
    "variants": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "size_enabled": { "type": "boolean", "default": false },
        "color_enabled": { "type": "boolean", "default": false },
        "sizes": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "label": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            ]
          },
          "default": []
        },
        "colors": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "label": { "type": "string" },
                  "hex_color": {
                    "type": "string",
                    "pattern": "^#[0-9a-fA-F]{6}$"
                  },
                  "description": { "type": "string" }
                }
              }
            ]
          },
          "default": []
        }
      }
    },
    "stripe_metadata": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "integer", "boolean", "null"]
      }
    },
    "prices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "Price.schema.json"
      }
    },
    "default_price_id": {
      "type": "string",
      "minLength": 1
    },
    "fulfillment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requires_shipping", "ship_from", "weight_lb", "dimensions"],
      "properties": {
        "requires_shipping": { "type": "boolean" },
        "ship_from": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "weight_lb": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "dimensions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["length_in", "width_in", "height_in"],
          "properties": {
            "length_in": { "type": ["number", "null"], "minimum": 0 },
            "width_in": { "type": ["number", "null"], "minimum": 0 },
            "height_in": { "type": ["number", "null"], "minimum": 0 }
          }
        }
      }
    },
    "sync": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "last_synced_at", "error"],
      "properties": {
        "status": {
          "type": ["string", "null"],
          "enum": ["pending", "success", "failed", "not_applicable", null]
        },
        "last_synced_at": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "error": {
          "type": ["string", "null"]
        }
      }
    },
    "created_at": {
      "type": "integer",
      "minimum": 0
    },
    "updated_at": {
      "type": "integer",
      "minimum": 0
    },
    "tags": {
      "type": "array",
      "description": "Search and catalog tags. The dashboard auto-generates baseline tags from product name, product type, and category; tenants can add custom tags.",
      "items": {
        "type": "string"
      },
      "default": []
    }
  }
}
