{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.juniorbay.com/stripe-link/Refund.schema.json",
  "title": "Refund",
  "description": "An immutable ledger row for a single refund against an order's charge. Written when a refund is executed from the dashboard or reconciled from a Stripe charge.refunded webhook. Partial refunds produce multiple rows.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "document_type", "tenant_id", "refund_id", "order_id", "amount", "created_at"],
  "properties": {
    "schema_version": { "type": "string", "const": "2026-05-29" },
    "document_type": { "type": "string", "const": "refund" },
    "tenant_id": { "type": "string", "minLength": 1 },
    "refund_id": { "type": "string", "minLength": 1, "description": "Our ledger id." },
    "order_id": { "type": "string", "minLength": 1 },
    "payment_intent_id": { "type": "string" },
    "charge_id": { "type": "string" },
    "amount": { "type": "integer", "minimum": 0, "description": "Refunded amount in cents." },
    "currency": { "type": "string" },
    "reason": { "type": "string" },
    "initiated_by": { "type": "string", "description": "admin | customer | stripe_dashboard | webhook." },
    "stripe_refund_id": { "type": "string", "description": "Stripe Refund id; unique per refund, used to dedupe reconciliation." },
    "status": { "type": "string", "description": "Stripe refund status: pending | succeeded | failed | canceled." },
    "created_at": { "type": "integer", "minimum": 0 }
  }
}
