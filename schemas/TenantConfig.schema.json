{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.juniorbay.com/stripe-link/TenantConfig.schema.json",
  "title": "TenantConfig",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "document_type", "tenant_id"],
  "properties": {
    "schema_version": { "type": "string", "const": "2026-05-29" },
    "document_type": { "type": "string", "const": "tenant_config" },
    "tenant_id": { "type": "string", "minLength": 1 },
    "default_currency": { "type": "string", "pattern": "^[a-z]{3}$", "default": "usd" },
    "environment": { "type": "string", "enum": ["dev", "prod", "test", "live"] },
    "system": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "api_endpoint": { "type": "string" },
        "environment_label": { "type": "string" },
        "dashboard_url": { "type": "string" },
        "checkout_base_url": { "type": "string" }
      }
    },
    "support": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "sms_notification_phone": {
          "type": "string",
          "description": "E.164 phone number used for tenant SMS/admin notifications."
        }
      }
    },
    "page_defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "upsell": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "headline": { "type": "string", "default": "Wait! Before You Go..." },
            "subheadline": { "type": "string", "default": "Exclusive One-Time Offer Just For You" },
            "accept_button_text": {
              "type": "string",
              "default": "Yes, I'll Take This Deal for {{ upsell_price }}",
              "description": "May include {{ upsell_price }} placeholder."
            },
            "decline_button_text": { "type": "string", "default": "No, Thank You! Let's Move On" }
          }
        },
        "thank_you": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "headline": { "type": "string", "default": "Thank You for Your Purchase!" },
            "subtitle": { "type": "string", "default": "Your Order Has Been Confirmed!" },
            "message": {
              "type": "string",
              "default": "Look for an email from us with further details on your order."
            }
          }
        }
      }
    },
    "checkout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "phone_number_collection": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "label": { "type": "string", "enum": ["Enabled", "Disabled"] },
            "description": { "type": "string" }
          }
        },
        "default_success_url": { "type": "string" },
        "default_cancel_url": { "type": "string" }
      }
    },
    "custom_domains": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "live_only": { "type": "boolean", "default": true },
        "dns_target": { "type": "string", "default": "domains.jbay.uk" },
        "domains": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["domain", "target_page_id", "status"],
            "properties": {
              "domain": { "type": "string" },
              "apex_domain": { "type": "string" },
              "registrar_provider": { "type": "string" },
              "target_type": { "type": "string", "enum": ["landing_page", "storefront"], "default": "landing_page" },
              "target_page_id": { "type": "string" },
              "cloudflare_hostname_id": { "type": "string", "description": "Cloudflare custom hostname resource ID, used to poll/delete the hostname without re-searching by name." },
              "status": {
                "type": "string",
                "enum": ["pending_dns", "pending_ssl", "pending_verification", "active", "failed", "disabled"]
              },
              "ssl_status": { "type": "string" },
              "validation_record": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "type": { "type": "string", "default": "TXT" },
                  "name": { "type": "string" },
                  "value": { "type": "string" }
                }
              },
              "created_at": { "type": "integer", "minimum": 0 },
              "updated_at": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    "legal_defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "terms_url": { "type": "string" },
        "privacy_url": { "type": "string" },
        "refund_url": { "type": "string" }
      }
    },
    "analytics_defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "google_tag_id": { "type": "string" },
        "pixel_id": { "type": "string" }
      }
    },
    "developer_tools": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "delete_test_data_enabled": { "type": "boolean", "default": false },
        "stripe_test_cards_visible": { "type": "boolean", "default": false },
        "stripe_test_cards": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "label": { "type": "string" },
              "number": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "updated_at": { "type": "integer", "minimum": 0 }
  }
}
