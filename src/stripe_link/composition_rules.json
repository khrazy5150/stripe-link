    "rating":               { "label": "Rating",           "ui": "add",    "kind": "capability", "channel": "body", "heading_role": "none", "repeatable": false, "tokens": ["content_text"] },
    "client_marquee":       { "label": "Client logos",     "ui": "add",    "kind": "capability", "channel": "body", "heading_role": "h2",   "repeatable": false, "tokens": ["content_heading", "content_border"] },
